rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins — any authenticated user can read (needed for client-side isAdmin() check)
    match /admins/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Valuations — authenticated users can read/write their own
    match /valuations/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Auto valuations — public write; admin read only
    match /auto_valuations/{docId} {
      allow create: if true;
      allow read: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update, delete: if false;
    }

    // Plate searches — public write; admin read only
    match /plate_searches/{docId} {
      allow create: if true;
      allow read: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update, delete: if false;
    }

    // Valuation feedback — public write; admin read only
    match /valuation_feedback/{docId} {
      allow create: if true;
      allow read: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update, delete: if false;
    }

    // Plate valuation message feedback — public write; admin read only
    match /plate_valuation_message_feedback/{docId} {
      allow create: if true;
      allow read: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update, delete: if false;
    }

    // Feature requests — write only
    match /feature_requests/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Mail — authenticated users only (triggers real email sends via Firebase Extension)
    match /mail/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Seller enquiries — authenticated users can create; sellers can read their own; admins can read all
    match /seller_enquiries/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && (request.auth.token.email == resource.data.sellerEmail
            || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow update, delete: if false;
    }

    // New plate listings — publicly readable; owner can update price/meanings; only server can create
    match /plate-listings-new/{docId} {
      allow read: if true;
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsPlaceholder']) ||
        (
          request.auth.uid == resource.data.sellerUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['askingPrice', 'meanings'])
        )
      );
      allow create, delete: if false;
    }

    // Legacy plate listings — publicly readable, view increment only
    match /plate-listings/{docId} {
      allow read: if true;
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsPlaceholder']) ||
        (
          request.auth.uid == resource.data.sellerUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['askingPrice', 'meanings'])
        )
      );
      allow create, delete: if false;
    }
  }
}
